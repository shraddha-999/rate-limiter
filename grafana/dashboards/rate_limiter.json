{
  "title": "Rate Limiter Dashboard",
  "uid": "rate-limiter-main",
  "version": 1,
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total Requests / sec",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(rate_limiter_requests_total[1m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 2,
      "title": "Allowed vs Blocked (1m rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(rate_limiter_requests_allowed_total[1m]))",
          "legendFormat": "Allowed"
        },
        {
          "expr": "sum(rate(rate_limiter_requests_blocked_total[1m]))",
          "legendFormat": "Blocked"
        }
      ]
    },
    {
      "id": 3,
      "title": "Block Rate %",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "100 * sum(rate(rate_limiter_requests_blocked_total[5m])) / (sum(rate(rate_limiter_requests_total[5m])) + 0.001)",
          "legendFormat": "Block %"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 4,
      "title": "P99 Request Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(rate_limiter_request_duration_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "P99"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(rate_limiter_request_duration_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "P50"
        }
      ]
    },
    {
      "id": 5,
      "title": "Redis Operation Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(rate_limiter_redis_operation_duration_seconds_bucket[1m])) by (le, operation)) * 1000",
          "legendFormat": "{{operation}} P99"
        }
      ]
    },
    {
      "id": 6,
      "title": "Redis Errors / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum(rate(rate_limiter_redis_errors_total[1m])) by (operation)",
          "legendFormat": "{{operation}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Requests by Algorithm",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "sum(rate_limiter_requests_total) by (algorithm)",
          "legendFormat": "{{algorithm}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Requests by Identifier Type",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 20 },
      "targets": [
        {
          "expr": "sum(rate_limiter_requests_total) by (identifier_type)",
          "legendFormat": "{{identifier_type}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "Config Reloads Total",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "rate_limiter_config_reloads_total",
          "legendFormat": "reloads"
        }
      ]
    }
  ]
}
