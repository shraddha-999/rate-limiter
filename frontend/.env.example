# Backend API URL
VITE_API_URL=http://localhost:8000

# App settings
VITE_APP_NAME=RateGuard
VITE_APP_VERSION=1.0.0

# Default credentials for demo mode
VITE_DEFAULT_ADMIN_KEY=change-me-in-production
VITE_DEFAULT_API_KEY=

# Polling intervals (milliseconds)
VITE_DASHBOARD_REFRESH_INTERVAL=5000
VITE_METRICS_REFRESH_INTERVAL=5000
VITE_HEALTH_REFRESH_INTERVAL=10000
