# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Rate Limiter API"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production

# ── Server ─────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ── Storage ────────────────────────────────────────────────────────────────────
# "redis" for production, "memory" for local dev/testing
STORAGE_BACKEND=redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=1.0
REDIS_RETRY_ON_TIMEOUT=true

# ── Rate Limiting Defaults ─────────────────────────────────────────────────────
DEFAULT_ALGORITHM=sliding_window   # fixed_window | sliding_window | token_bucket
DEFAULT_LIMIT=100
DEFAULT_WINDOW_SECONDS=60
DEFAULT_BURST_CAPACITY=20
DEFAULT_REFILL_RATE=1.67

# ── User Tiers ─────────────────────────────────────────────────────────────────
FREE_TIER_LIMIT=100
PREMIUM_TIER_LIMIT=1000
ENTERPRISE_TIER_LIMIT=999999

# ── Security ───────────────────────────────────────────────────────────────────
ADMIN_API_KEY=change-me-in-production
# Comma-separated list of allowed API keys (leave empty to skip API key auth)
ALLOWED_API_KEYS=

# Comma-separated IPs that bypass all rate limiting
WHITELIST_IPS=127.0.0.1

# Comma-separated IPs that are always blocked
BLACKLIST_IPS=

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json   # json | text

# ── Monitoring ─────────────────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
METRICS_PATH=/metrics

# ── Grafana (docker-compose only) ──────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
